# Supabase (required for products, catalogue, orders)
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Airtable (order tracking sheet)
# 1. Create a base at airtable.com with a table named "Orders"
# 2. Get your Personal Access Token: airtable.com/create/tokens (scope: data.records:write)
# 3. Get Base ID from the URL: airtable.com/appXXXXXXXX/... → appXXXXXXXX is your Base ID
VITE_AIRTABLE_TOKEN=your-airtable-personal-access-token
VITE_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
VITE_AIRTABLE_TABLE=Orders

# Telegram (instant mobile push on new order)
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Start your bot, then visit: https://api.telegram.org/bot<TOKEN>/getUpdates
#    Send any message to your bot first, then find "chat":{"id": XXXXXXX} — that's your Chat ID
VITE_TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
VITE_TELEGRAM_CHAT_ID=your-chat-id

# Trustpilot (optional for reviews page)
# Get your Business ID from: https://businessapp.b2b.trustpilot.com/
# Navigate to Settings → Widgets to find your Business Unit ID
VITE_TRUSTPILOT_BUSINESS_ID=your-trustpilot-business-id
